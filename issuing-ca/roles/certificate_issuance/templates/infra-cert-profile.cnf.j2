#
# {{ ansible_managed }}
# NOMMA Infrastructure Certificate Profile
# For LDAP, RADIUS, mail, and other infrastructure services.

[ req ]
default_bits            = 2048
default_md              = sha384
prompt                  = no
encrypt_key             = yes
distinguished_name      = req_distinguished_name
req_extensions          = req_ext

[ req_distinguished_name ]
countryName             = {{ pki_country }}
stateOrProvinceName     = {{ pki_state }}
localityName            = {{ pki_locality }}
organizationName        = {{ pki_organization }}
organizationalUnitName  = {{ pki_org_unit }}
# REPLACE with service hostname:
commonName              = service.nomma.lan

[ req_ext ]
subjectAltName          = @alt_names

[ alt_names ]
# REPLACE with actual DNS names:
DNS.1 = service.nomma.lan